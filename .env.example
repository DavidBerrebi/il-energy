# il-energy — environment variable reference
# Copy this file to .env and fill in your local values.
# .env is gitignored and must never be committed.

# ── EnergyPlus installation ───────────────────────────────────────────────────
# Path to the EnergyPlus installation directory.
# ENERGYPLUS_DIR is the preferred name; ENERGYPLUS_PATH is also accepted.
# If unset, the engine auto-detects the newest install in the platform default
# location (see config.py for the full resolution order).
#
# macOS default:   /Applications/EnergyPlus-25-2-0
# Linux default:   /usr/local/EnergyPlus-25-2-0
# Windows default: C:\EnergyPlusV25-2-0
#
ENERGYPLUS_DIR=/Applications/EnergyPlus-25-2-0
# ENERGYPLUS_PATH=/Applications/EnergyPlus-25-2-0   # alias — either name works

# ── EnergyPlus version (informational) ───────────────────────────────────────
# Documenting which version is installed. Not read by the engine at runtime;
# the binary version is detected automatically from the installation directory.
ENERGYPLUS_VERSION=25.2.0
